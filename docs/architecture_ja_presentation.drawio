        <mxCell id="naturalness" value="pipeline/naturalness.py&#xa;自然さ評価&#xa;mean_abs_diff + edge_delta + 合成スコア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_app" vertex="1">
