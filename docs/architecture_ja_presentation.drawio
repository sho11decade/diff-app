        </mxCell>
        <mxCell id="client_demo" value="デモUI（HTMX）&#xa;- 画像アップロード・プレビュー&#xa;- パラメータ指定&#xa;- クリックゲーム" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_client" vertex="1">
          <mxGeometry x="165" y="40" width="175" height="120" as="geometry" />
        </mxCell>
        <mxCell id="client_api" value="API利用（研究/運用）&#xa;POST /generate&#xa;GET /experiments/{trace_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane_client" vertex="1">
          <mxGeometry x="20" y="185" width="320" height="95" as="geometry" />
        </mxCell>
        <mxCell id="lane_app" value="2. アプリケーション層（FastAPI）" style="swimlane;html=1;rounded=1;arcSize=8;strokeWidth=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="420" y="95" width="760" height="575" as="geometry" />
        </mxCell>
        <mxCell id="app_factory" value="app_factory.py&#xa;アプリ初期化&#xa;Router登録 / 静的配信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="lane_app" vertex="1">
          <mxGeometry x="20" y="40" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="router_demo" value="demo.py&#xa;GET /demo&#xa;POST /demo/process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane_app" vertex="1">
          <mxGeometry x="260" y="40" width="210" height="96" as="geometry" />
        </mxCell>
        <mxCell id="router_generate" value="generate.py&#xa;POST /generate&#xa;GET /health&#xa;GET /experiments/{trace_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_app" vertex="1">
          <mxGeometry x="490" y="40" width="240" height="96" as="geometry" />
        </mxCell>
        <mxCell id="security" value="core/security.py&#xa;API Key検証&#xa;レート制限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lane_app" vertex="1">
          <mxGeometry x="20" y="165" width="220" height="86" as="geometry" />
        </mxCell>
        <mxCell id="config" value="core/config.py&#xa;難易度プロファイル&#xa;閾値の環境変数化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="lane_app" vertex="1">
          <mxGeometry x="20" y="270" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="generator" value="pipeline/generator.py&#xa;差分生成オーケストレーション&#xa;- 領域選択（背景回避）&#xa;- 密集防止（中心距離 + IoU制約）&#xa;- 品質ゲート + 自己改善 + フォールバック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_app" vertex="1">
