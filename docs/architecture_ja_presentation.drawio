        <mxCell id="editors" value="pipeline/editors.py&#xa;編集操作&#xa;brightness / color / contrast / shift / flip&#xa;不定形マスク + フェザーブレンド" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="lane_app" vertex="1">
