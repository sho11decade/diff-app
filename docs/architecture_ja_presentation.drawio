<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.0.3 Chrome/140.0.7339.249 Electron/38.7.0 Safari/537.36" version="29.0.3">
  <diagram id="diff-app-ja-architecture" name="Diff App アーキテクチャ（日本語）">
    <mxGraphModel dx="1303" dy="903" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lane_client" value="1. 利用者・フロント層" style="swimlane;html=1;rounded=1;arcSize=8;strokeWidth=1;fillColor=#008a00;strokeColor=#005700;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="30" y="95" width="360" height="330" as="geometry" />
        </mxCell>
        <mxCell id="client_browser" value="ブラウザ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane_client" vertex="1">
